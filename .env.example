# ─────────────────────────────────────────────
# ClickHouse
# ─────────────────────────────────────────────
CLICKHOUSE_VERSION=24.3
CLICKHOUSE_DB=analytics
CLICKHOUSE_USER=analytics
CLICKHOUSE_PASSWORD=change_me_clickhouse
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000

# ─────────────────────────────────────────────
# PostgreSQL (Metabase metadata store)
# ─────────────────────────────────────────────
POSTGRES_VERSION=16-alpine
MB_DB_DBNAME=metabase
MB_DB_USER=metabase
MB_DB_PASS=change_me_postgres

# ─────────────────────────────────────────────
# Metabase
# ─────────────────────────────────────────────
METABASE_VERSION=v0.52.5
CLICKHOUSE_DRIVER_VERSION=1.52.0
METABASE_PORT=3000
MB_SITE_URL=http://localhost:3000
MB_SITE_NAME=Analytics Platform
MB_EMAIL_FROM_ADDRESS=analytics@example.com
MB_JAVA_MAX_MEM=2g
MB_JAVA_MIN_MEM=512m
